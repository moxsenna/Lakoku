{
  "$schema": "node_modules/wrangler/config-schema.json",
  "main": ".open-next/worker.js",
  "name": "lakoku-v2",
  // 2025-11-01: di atas min OpenNext (2024-12-30) + FinalizationRegistry fix
  // (2025-05-05), dan aman di masa lalu relatif runtime wrangler v4.
  "compatibility_date": "2025-11-01",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  // Aktifkan Workers Logs supaya request/error runtime bisa ditelusuri di prod
  // (menutup gap request-log correlation di STAGING_QA_WEB_RELEASE.md).
  "observability": {
    "enabled": true
  },
  // Menyalakan jalur LLM nyata (lib/ai-gateway/select-provider.ts). Tanpa ini
  // runtime fallback ke provider deterministik.
  "vars": {
    "NARRATIVE_PROVIDER": "gateway"
  }
  // SECRETS WAJIB di worker `lakoku-v2` (set via `wrangler secret put <NAME>`):
  //   - SUPABASE_SERVICE_ROLE_KEY   ✅ sudah terpasang
  //   - AI_GATEWAY_API_KEY          ✅ sudah terpasang
  //   - RUNTIME_ADMIN_TOKEN         → endpoint generate/admin fail-closed 503 tanpa ini
  //   - CHECKOUT_WEBHOOK_SECRET     → webhook checkout 503 tanpa ini (monetisasi)
  // Env staging/production terpisah bisa ditambahkan lewat blok "env": {...}
  // bila nanti butuh isolasi (menuntut penyalinan ulang semua secret per env).
}
