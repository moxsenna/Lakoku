{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "target": "ES6",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@lakoku/narrative-core": [
        "./lib/narrative/index.ts"
      ],
      "@lakoku/narrative-core/server": [
        "./lib/narrative/server.ts"
      ],
      "@lakoku/ai-gateway": [
        "./lib/ai-gateway/index.ts"
      ],
      "@lakoku/ai-gateway/server": [
        "./lib/ai-gateway/server.ts"
      ],
      "@lakoku/runtime": [
        "./lib/runtime/index.ts"
      ],
      "@lakoku/db": [
        "./lib/supabase/index.ts"
      ],
      "@lakoku/authoring": [
        "./lib/authoring/index.ts"
      ],
      "@lakoku/authoring/server": [
        "./lib/authoring/server.ts"
      ],
      "@lakoku/api": [
        "./lib/api/index.ts"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
